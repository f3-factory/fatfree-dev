{
    "name": "f3-factory/fatfree-dev",
    "license": "MIT",
    "minimum-stability": "stable",
    "type": "project",
    "description": "Dockerized development environment for the PHP Fat-Free Framework",
    "keywords": ["F3","fatfree","micro-framework","php"],
    "homepage": "https://github.com/f3-factory/fatfree-dev",
    "require": {
        "php": ">=8.4",
        "bcosca/fatfree-core": "v4.x-dev as 4.0.0",
        "f3-factory/fatfree-psr7": "^2.0",
        "f3-factory/fatfree-psr7-factory": "^1.0",
        "f3-factory/f3-overdrive": "dev-main as 1.0.0",
        "imefisto/psr-swoole-native": "^v1.0",
        "spiral/roadrunner-cli": "2.x-dev",
        "spiral/roadrunner-http": "^3.3.0",
        "openswoole/core": "^22.2.0",
        "openswoole/ide-helper": "^22.1.5",
        "psr/http-message": "^1.1 || ^2.0",
        "mongodb/mongodb": "^2.1.2"
    },
    "repositories": [
        {
            "type": "path",
            "url": "./lib",
            "canonical": true,
            "no-api": true
        }
    ],
    "require-dev": {
        "swoole/ide-helper": "~5.0.0",
        "pestphp/pest": "^4.3.2",
        "pestphp/pest-plugin-type-coverage": "^4.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "test:type-coverage": "vendor/bin/pest --type-coverage"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
